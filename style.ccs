body { font-family: sans-serif; background-color: #1a1a1a; color: white; padding: 20px; }
.grid-container { 
    display: grid; 
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); 
    gap: 20px; 
}
.tropa-card { 
    background: #333; 
    padding: 10px; 
    border-radius: 8px; 
    text-align: center; 
}
.tropa-card img { 
    max-width: 100%; 
    height: auto; 
    border-radius: 4px; 
}
